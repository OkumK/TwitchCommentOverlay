{
  "manifest_version": 3,
  "name": "Twitch Comment Overlay",
  "description": "Display Twitch chat messages as an overlay on Twitch watch pages.",
  "version": "0.1.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["settings.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Twitch Comment Overlay",
    "default_popup": "popup.html"
  }
}
